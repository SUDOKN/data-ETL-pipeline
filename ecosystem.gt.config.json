{
  "apps": [
    {
      "name": "litellm-proxy",
      "script": "./.venv/bin/litellm",
      "interpreter": "none",
      "args": "--config ./litellm_proxy_app/src/litellm_proxy_app/config/litellm.yaml --port 4000",
      "cwd": "./",
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "512M",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "error_file": "./logs/litellm-proxy-error.log",
      "out_file": "./logs/litellm-proxy-out.log",
      "log_file": "./logs/litellm-proxy-combined.log",
      "time": true,
      "kill_timeout": 5000,
      "shutdown_with_message": false,
      "listen_timeout": 30000,
      "wait_ready": false,
      "max_restarts": 5,
      "min_uptime": "30s",
      "restart_delay": 5000,
      "env": {
        "DATABASE_URL": "postgresql://litellm:litellm@localhost:5432/litellm",
        "LITELLM_MASTER_KEY": "sk-master-key-local-sudokn-amar",
        "PYTHONUNBUFFERED": "1",
        "PATH": "/Users/amaryadav/Documents/ASU_PhD/SUDOKN/data-ETL-pipeline/.venv/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    {
      "name": "gt-sq-bot",
      "description": "This bot uses the same s3 bucket as regular scrape bots but interacts with sudokn-new db with the new updated db models.",
      "script": "./scraper_app/src/scraper_app/bots/gt_scrape_queue_bot.py",
      "interpreter": "./.venv/bin/python3",
      "args": "--priority 1 --max_concurrent_browsers 2 --max_depth 5 --scrape_timeout 60",
      "cwd": "./",
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "2G",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "error_file": "./logs/gt-sq-bot-priority-error.log",
      "out_file": "./logs/gt-sq-bot-priority-out.log",
      "log_file": "./logs/gt-sq-bot-priority-combined.log",
      "time": true,
      "kill_timeout": 10000,
      "shutdown_with_message": true,
      "listen_timeout": 8000,
      "wait_ready": false,
      "max_restarts": 5,
      "min_uptime": "10s",
      "restart_delay": 2000,
      "env": {
        "PYTHONPATH": "./scraper_app/src:./core/src:./open_ai_key_app/src:./litellm_proxy_app/src",
        "PYTHONUNBUFFERED": "1",
        "VIRTUAL_ENV": "./.venv",
        "PATH": "./.venv/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    {
      "name": "gt-eq-bot",
      "description": "This bot uses the sudokn-new db and updated db models. It extracts using only the first 10 chunks wherever applicable",
      "script": "./data_etl_app/src/data_etl_app/bots/gt_extract_queue_bot.py",
      "interpreter": "./.venv/bin/python3",
      "args": "--priority 0 --max_concurrent_manufacturers 25 --debug INFO",
      "cwd": "./",
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "1G",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "error_file": "./logs/gt-extract-queue-bot-error.log",
      "out_file": "./logs/gt-extract-queue-bot-out.log",
      "log_file": "./logs/gt-extract-queue-bot-combined.log",
      "time": true,
      "kill_timeout": 2000,
      "shutdown_with_message": true,
      "listen_timeout": 8000,
      "wait_ready": false,
      "max_restarts": 5,
      "min_uptime": "10s",
      "restart_delay": 5000,
      "env": {
        "PYTHONPATH": "./data_etl_app/src:./core/src:./open_ai_key_app/src",
        "PYTHONUNBUFFERED": "1",
        "VIRTUAL_ENV": "./.venv",
        "PATH": "./.venv/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    {
      "name": "gt-api",
      "description": "This is the new API server for GT running on 8001. It uses the sudokn-new db and updated db models.",
      "script": "./.venv/bin/python3",
      "interpreter": "none",
      "args": "-m gunicorn data_etl_app.main:app -w 1 -k uvicorn.workers.UvicornWorker --bind 0.0.0.0:8001 --timeout 120 --max-requests 1000 --preload --log-level info",
      "cwd": "./",
      "instances": 1,
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "1G",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "error_file": "./logs/data-etl-gt-api-error.log",
      "out_file": "./logs/data-etl-gt-api-out.log",
      "log_file": "./logs/data-etl-gt-api-combined.log",
      "time": true,
      "kill_timeout": 1000,
      "shutdown_with_message": true,
      "listen_timeout": 8000,
      "wait_ready": false,
      "max_restarts": 5,
      "min_uptime": "10s",
      "restart_delay": 5000,
      "env": {
        "PYTHONPATH": "./data_etl_app/src:./core/src:./open_ai_key_app/src:./scraper_app/src:./litellm_proxy_app/src",
        "PYTHONUNBUFFERED": "1",
        "NODE_ENV": "production",
        "LOG_LEVEL": "INFO",
        "VIRTUAL_ENV": "./.venv",
        "PATH": "./.venv/bin:/usr/local/bin:/usr/bin:/bin"
      }
    }
  ]
}
