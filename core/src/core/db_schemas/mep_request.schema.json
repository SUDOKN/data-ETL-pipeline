{
  "$jsonSchema": {
    "bsonType": "object",
    "required": [
      "userEmail"
    ],
    "additionalProperties": false,
    "properties": {
      "_id": {
        "bsonType": "objectId"
      },
      "userEmail": {
        "bsonType": "string"
      },
      "status": {
        "enum": [
          "pending",
          "approved",
          "rejected"
        ],
        "bsonType": "string"
      },
      "reason": {
        "bsonType": [
          "string",
          "null"
        ]
      },
      "createdAt": {
        "bsonType": "date"
      },
      "updatedAt": {
        "bsonType": "date"
      }
    }
  }
}
