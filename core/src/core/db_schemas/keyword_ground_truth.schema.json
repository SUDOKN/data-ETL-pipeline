{
  "$jsonSchema": {
    "bsonType": "object",
    "required": [
      "mfg_etld1",
      "scraped_text_file_version_id",
      "keyword_type",
      "chunk_bounds",
      "chunk_no",
      "last_chunk_no",
      "chunk_text",
      "metadata",
      "extraction_stats",
      "corrections"
    ],
    "additionalProperties": false,
    "properties": {
      "_id": {
        "bsonType": "objectId"
      },
      "created_at": {
        "bsonType": "date"
      },
      "updated_at": {
        "bsonType": "date"
      },
      "mfg_etld1": {
        "bsonType": "string"
      },
      "scraped_text_file_version_id": {
        "bsonType": "string"
      },
      "keyword_type": {
        "enum": [
          "products"
        ],
        "bsonType": "string"
      },
      "chunk_bounds": {
        "bsonType": "string"
      },
      "chunk_no": {
        "bsonType": "int"
      },
      "last_chunk_no": {
        "bsonType": "int"
      },
      "chunk_text": {
        "bsonType": "string"
      },
      "metadata": {
        "bsonType": "object",
        "required": [
          "model",
          "model_params",
          "created_at",
          "chunk_strat",
          "search_prompt_version_id"
        ],
        "additionalProperties": false,
        "properties": {
          "model": {
            "bsonType": "string"
          },
          "model_params": {
            "bsonType": "object",
            "required": [
              "max_completion_tokens",
              "temperature",
              "top_p",
              "presence_penalty",
              "frequency_penalty"
            ],
            "additionalProperties": false,
            "properties": {
              "reasoning_effort": {
                "enum": [
                  "low",
                  "medium",
                  "high",
                  null
                ],
                "bsonType": [
                  "string",
                  "null"
                ]
              },
              "logit_bias": {
                "bsonType": [
                  "object",
                  "null"
                ],
                "additionalProperties": {
                  "bsonType": "int"
                }
              },
              "user": {
                "bsonType": [
                  "string",
                  "null"
                ]
              },
              "tools": {
                "bsonType": [
                  "array",
                  "null"
                ],
                "items": {
                  "bsonType": "object"
                }
              },
              "tool_choice": {
                "anyOf": [
                  {
                    "bsonType": "string"
                  },
                  {
                    "bsonType": "object"
                  },
                  {
                    "bsonType": "null"
                  }
                ]
              },
              "parallel_tool_calls": {
                "bsonType": [
                  "bool",
                  "null"
                ]
              },
              "logprobs": {
                "bsonType": [
                  "bool",
                  "null"
                ]
              },
              "top_logprobs": {
                "bsonType": [
                  "int",
                  "null"
                ]
              },
              "max_completion_tokens": {
                "bsonType": "int"
              },
              "stop": {
                "anyOf": [
                  {
                    "bsonType": "string"
                  },
                  {
                    "bsonType": "array",
                    "items": {
                      "bsonType": "string"
                    }
                  },
                  {
                    "bsonType": "null"
                  }
                ]
              },
              "n": {
                "bsonType": [
                  "int",
                  "null"
                ]
              },
              "response_format": {
                "bsonType": [
                  "object",
                  "null"
                ]
              },
              "temperature": {
                "bsonType": "double"
              },
              "top_p": {
                "bsonType": "double"
              },
              "presence_penalty": {
                "bsonType": "double"
              },
              "frequency_penalty": {
                "bsonType": "double"
              },
              "seed": {
                "bsonType": [
                  "int",
                  "null"
                ]
              }
            }
          },
          "created_at": {
            "bsonType": "date"
          },
          "chunk_strat": {
            "bsonType": "object",
            "required": [
              "overlap",
              "max_chunks",
              "max_tokens_per_chunk"
            ],
            "additionalProperties": false,
            "properties": {
              "overlap": {
                "bsonType": "double"
              },
              "max_chunks": {
                "bsonType": "int"
              },
              "max_tokens_per_chunk": {
                "bsonType": "int"
              }
            }
          },
          "search_prompt_version_id": {
            "bsonType": "string"
          }
        }
      },
      "extraction_stats": {
        "bsonType": "object",
        "required": [
          "results",
          "llm_search"
        ],
        "additionalProperties": false,
        "properties": {
          "results": {
            "bsonType": "array",
            "items": {
              "bsonType": "string"
            },
            "uniqueItems": true
          },
          "llm_search": {
            "bsonType": "array",
            "items": {
              "bsonType": "string"
            },
            "uniqueItems": true
          }
        }
      },
      "corrections": {
        "bsonType": "array",
        "items": {
          "bsonType": "object",
          "required": [
            "created_at",
            "human_correction"
          ],
          "additionalProperties": false,
          "properties": {
            "created_at": {
              "bsonType": "date"
            },
            "human_correction": {
              "bsonType": "object",
              "required": [
                "author_email",
                "source",
                "llm_search"
              ],
              "additionalProperties": false,
              "properties": {
                "author_email": {
                  "bsonType": "string"
                },
                "source": {
                  "enum": [
                    "user_form",
                    "api_survey"
                  ],
                  "bsonType": "string"
                },
                "llm_search": {
                  "bsonType": "object",
                  "required": [
                    "add",
                    "remove"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "add": {
                      "bsonType": "array",
                      "items": {
                        "bsonType": "string"
                      }
                    },
                    "remove": {
                      "bsonType": "array",
                      "items": {
                        "bsonType": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
