{
  "$jsonSchema": {
    "bsonType": "object",
    "required": [
      "created_at",
      "updated_at",
      "mfg_etld1",
      "scraped_text_file_version_id",
      "keyword_type",
      "chunk_bounds",
      "chunk_no",
      "last_chunk_no",
      "chunk_text",
      "metadata",
      "chunk_search_stats",
      "corrections"
    ],
    "additionalProperties": false,
    "properties": {
      "_id": {
        "bsonType": "objectId"
      },
      "created_at": {
        "bsonType": "date"
      },
      "updated_at": {
        "bsonType": "date"
      },
      "mfg_etld1": {
        "bsonType": "string"
      },
      "scraped_text_file_version_id": {
        "bsonType": "string"
      },
      "keyword_type": {
        "enum": ["products"]
      },
      "chunk_bounds": {
        "bsonType": "string"
      },
      "chunk_no": {
        "bsonType": "int"
      },
      "last_chunk_no": {
        "bsonType": "int"
      },
      "chunk_text": {
        "bsonType": "string"
      },
      "metadata": {
        "bsonType": "object",
        "required": ["model", "created_at", "search_prompt_version_id"],
        "additionalProperties": false,
        "properties": {
          "model": { "bsonType": "string" },
          "created_at": { "bsonType": "date" },
          "search_prompt_version_id": { "bsonType": "string" }
        }
      },
      "chunk_search_stats": {
        "bsonType": "object",
        "required": ["results", "llm_search"],
        "additionalProperties": false,
        "properties": {
          "results": {
            "bsonType": "array",
            "uniqueItems": true,
            "items": { "bsonType": "string" }
          },
          "llm_search": {
            "bsonType": "array",
            "uniqueItems": true,
            "items": { "bsonType": "string" }
          }
        }
      },
      "corrections": {
        "bsonType": "array",
        "items": {
          "bsonType": "object",
          "required": ["created_at", "human_correction"],
          "additionalProperties": false,
          "properties": {
            "created_at": {
              "bsonType": "date"
            },
            "human_correction": {
              "bsonType": "object",
              "required": ["author_email", "source", "llm_search"],
              "additionalProperties": false,
              "properties": {
                "author_email": { "bsonType": "string" },
                "source": {
                  "bsonType": "string",
                  "enum": ["user_form", "api_survey"]
                },
                "llm_search": {
                  "bsonType": "object",
                  "required": ["add", "remove"],
                  "additionalProperties": false,
                  "properties": {
                    "add": {
                      "bsonType": "array",
                      "items": { "bsonType": "string" }
                    },
                    "remove": {
                      "bsonType": "array",
                      "items": { "bsonType": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
