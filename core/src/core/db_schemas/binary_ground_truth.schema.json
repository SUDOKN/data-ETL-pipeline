{
  "$jsonSchema": {
    "bsonType": "object",
    "required": [
      "created_at",
      "updated_at",
      "mfg_etld1",
      "scraped_text_file_version_id",
      "classification_type",
      "metadata",
      "extraction_stats",
      "corrections"
    ],
    "additionalProperties": false,
    "properties": {
      "_id": { "bsonType": "objectId" },
      "created_at": { "bsonType": "date" },
      "updated_at": { "bsonType": "date" },
      "mfg_etld1": { "bsonType": "string" },
      "scraped_text_file_version_id": { "bsonType": "string" },
      "classification_type": {
        "bsonType": "string",
        "enum": [
          "is_manufacturer",
          "is_product_manufacturer",
          "is_contract_manufacturer"
        ]
      },
      "metadata": {
        "bsonType": "object",
        "required": ["model", "created_at", "prompt_version_id"],
        "additionalProperties": false,
        "properties": {
          "model": { "bsonType": "string" },
          "created_at": { "bsonType": "date" },
          "prompt_version_id": { "bsonType": "string" }
        }
      },
      "extraction_stats": {
        "bsonType": "object",
        "required": ["result"],
        "additionalProperties": false,
        "properties": {
          "result": {
            "bsonType": "object",
            "required": ["answer", "confidence", "reason"],
            "additionalProperties": false,
            "properties": {
              "answer": { "bsonType": "bool" },
              "confidence": { "bsonType": "int" },
              "reason": { "bsonType": "string" }
            }
          }
        }
      },
      "corrections": {
        "bsonType": "array",
        "items": {
          "bsonType": "object",
          "required": ["created_at", "human_decision"],
          "additionalProperties": false,
          "properties": {
            "created_at": { "bsonType": "date" },
            "human_decision": {
              "bsonType": "object",
              "required": ["author_email", "source", "answer"],
              "additionalProperties": false,
              "properties": {
                "author_email": { "bsonType": "string" },
                "source": {
                  "bsonType": "string",
                  "enum": ["user_form", "api_survey"]
                },
                "answer": { "bsonType": ["bool"] },
                "reason": { "bsonType": ["string", "null"] }
              }
            }
          }
        }
      }
    }
  }
}
