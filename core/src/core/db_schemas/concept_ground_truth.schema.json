{
  "$jsonSchema": {
    "bsonType": "object",
    "required": [
      "created_at",
      "updated_at",
      "mfg_etld1",
      "scraped_text_file_version_id",
      "concept_type",
      "chunk_bounds",
      "chunk_no",
      "last_chunk_no",
      "metadata",
      "extraction_stats",
      "corrections"
    ],
    "additionalProperties": false,
    "properties": {
      "_id": { "bsonType": "objectId" },
      "created_at": { "bsonType": "date" },
      "updated_at": { "bsonType": "date" },
      "mfg_etld1": { "bsonType": "string" },
      "scraped_text_file_version_id": { "bsonType": "string" },
      "concept_type": {
        "enum": ["industries", "certificates", "material_caps", "process_caps"]
      },
      "chunk_bounds": { "bsonType": "string" },
      "chunk_no": { "bsonType": "int" },
      "last_chunk_no": { "bsonType": "int" },
      "metadata": {
        "bsonType": "object",
        "required": [
          "model",
          "created_at",
          "search_prompt_version_id",
          "ontology_version_id"
        ],
        "additionalProperties": false,
        "properties": {
          "model": { "bsonType": "string" },
          "created_at": { "bsonType": "date" },
          "search_prompt_version_id": { "bsonType": "string" },
          "ontology_version_id": { "bsonType": "string" },
          "evidence_prompt_version_id": { "bsonType": ["string", "null"] },
          "mapping_prompt_version_id": { "bsonType": ["string", "null"] }
        }
      },
      "extraction_stats": {
        "bsonType": "object",
        "required": [
          "results",
          "brute_search",
          "llm_search",
          "llm_evidence",
          "llm_mapping",
          "unmapped"
        ],
        "additionalProperties": false,
        "properties": {
          "results": {
            "bsonType": "array",
            "uniqueItems": true,
            "items": { "bsonType": "string" }
          },
          "brute_search": {
            "bsonType": "array",
            "uniqueItems": true,
            "items": { "bsonType": "string" }
          },
          "llm_search": {
            "bsonType": "array",
            "uniqueItems": true,
            "items": { "bsonType": "string" }
          },
          "llm_evidence": {
            "bsonType": "object",
            "additionalProperties": { "bsonType": ["string", "null"] }
          },
          "llm_mapping": {
            "bsonType": "object",
            "additionalProperties": {
              "bsonType": "array",
              "items": { "bsonType": "string" }
            }
          },
          "unmapped": {
            "bsonType": "array",
            "uniqueItems": true,
            "items": { "bsonType": "string" }
          }
        }
      },
      "corrections": {
        "bsonType": "array",
        "items": {
          "bsonType": "object",
          "required": ["created_at", "human_correction"],
          "additionalProperties": false,
          "properties": {
            "created_at": { "bsonType": "date" },
            "human_correction": {
              "bsonType": "object",
              "required": [
                "author_email",
                "source",
                "llm_evidence",
                "llm_mapping"
              ],
              "additionalProperties": false,
              "properties": {
                "author_email": { "bsonType": "string" },
                "source": {
                  "bsonType": "string",
                  "enum": ["user_form", "api_survey"]
                },
                "llm_evidence": {
                  "bsonType": "object",
                  "required": ["upsert", "remove"],
                  "additionalProperties": false,
                  "properties": {
                    "upsert": {
                      "bsonType": "object",
                      "additionalProperties": {
                        "bsonType": "array",
                        "items": { "bsonType": "string" }
                      }
                    },
                    "remove": {
                      "bsonType": "array",
                      "items": { "bsonType": "string" }
                    }
                  }
                },
                "llm_mapping": {
                  "bsonType": "object",
                  "required": ["upsert", "remove"],
                  "additionalProperties": false,
                  "properties": {
                    "upsert": {
                      "bsonType": "object",
                      "additionalProperties": {
                        "bsonType": "array",
                        "items": { "bsonType": "string" }
                      }
                    },
                    "remove": {
                      "bsonType": "array",
                      "items": { "bsonType": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
