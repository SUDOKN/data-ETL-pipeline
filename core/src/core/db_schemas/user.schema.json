{
  "$jsonSchema": {
    "bsonType": "object",
    "required": [
      "firstName",
      "lastName",
      "email",
      "salt",
      "hashedPassword"
    ],
    "additionalProperties": false,
    "properties": {
      "_id": {
        "bsonType": "objectId"
      },
      "firstName": {
        "bsonType": "string"
      },
      "lastName": {
        "bsonType": "string"
      },
      "email": {
        "bsonType": "string"
      },
      "role": {
        "enum": [
          "default",
          "employee",
          "mep",
          "admin"
        ],
        "bsonType": "string"
      },
      "companyURL": {
        "bsonType": [
          "string",
          "null"
        ]
      },
      "salt": {
        "bsonType": "string"
      },
      "hashedPassword": {
        "bsonType": "string"
      },
      "resetPwdToken": {
        "bsonType": [
          "string",
          "null"
        ]
      },
      "createdAt": {
        "bsonType": "date"
      },
      "updatedAt": {
        "bsonType": "date"
      }
    }
  }
}
